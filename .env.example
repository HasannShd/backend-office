MONGO_URI=mongodb+srv://<db-user>:<db-password>@<cluster-host>/lte?retryWrites=true&w=majority
JWT_SECRET=<replace-with-a-long-random-secret>
PORT=5000
CLIENT_URL=http://localhost:5173
CLIENT_URL_2=https://www.example.com
CLIENT_URL_3=https://example.com
ALLOWED_ORIGINS=http://localhost:5173,https://www.example.com,https://example.com
AUTH_COOKIE_SAME_SITE=lax
ENFORCE_ADMIN_MFA=true
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@example.com
SMTP_PASS=<replace-with-your-smtp-password>
SMTP_FROM=LTE <noreply@example.com>

ORDER_NOTIFY_EMAIL=orders@example.com
SALES_ORDER_NOTIFY_EMAIL=sales-orders@example.com
CAREERS_NOTIFY_EMAIL=careers@example.com

CLOUDINARY_CLOUD_NAME=<cloudinary-cloud-name>
CLOUDINARY_API_KEY=<cloudinary-api-key>
CLOUDINARY_API_SECRET=<cloudinary-api-secret>
MFA_ENCRYPTION_KEY=<replace-with-a-long-random-secret>
BACKUP_ENCRYPTION_KEY=<replace-with-a-long-random-secret>
